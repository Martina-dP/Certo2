model Company {
  id           String  @id @default(cuid())
  businessName String // nombre que aparece en las facturas (razón social de la empresa)
  tradeName    String? // es el nombre comercial
  taxId        String? @unique
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  logoUrl      String?
  currency     String  @default("ARS")
  timezone     String  @default("America/Argentina/Buenos_Aires")
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  roles     Role[]
  customers Customer[]
}
